generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// SQLite does not support enums, using String instead

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?   // text
  access_token      String?   // text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?   // text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  passwordHash      String?
  name              String
  image             String?
  role              String    @default("cliente")
  twoFactorEnabled  Boolean   @default(false)
  twoFactorSecret   String?
  isActive          Boolean   @default(true)
  lastLoginAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  owner             Owner?     @relation(fields: [ownerId], references: [id])
  ownerId           String?    @unique
  accounts          Account[]
  sessions          Session[]
  staffAppointments Appointment[] @relation("StaffAppointments")
  auditLogs         AuditLog[]
  calendarToken     GoogleCalendarToken?

  @@map("users")
}

model Owner {
  id                  String             @id @default(cuid())
  name                String
  email               String?
  phone               String?
  address             String?
  notes               String?
  source              String             @default("presencial")
  prefChannel         String             @default("whatsapp")
  marketingConsent    Boolean            @default(false)
  marketingConsentAt  DateTime?
  dataRetentionUntil  DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  user                  User?
  pets                  PetOwner[]
  appointments          Appointment[]
  productSales          ProductSale[]
  notifications         Notification[]
  notificationConfigs   NotificationConfig[]
  consentRecords        ConsentRecord[]
  dataDeletionRequests  DataDeletionRequest[]

  @@map("owners")
}

model Pet {
  id         String   @id @default(cuid())
  name       String
  breed      String?
  size       String
  birthDate  DateTime?
  photoUrl   String?
  notes      String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  owners      PetOwner[]
  appointments Appointment[]

  @@map("pets")
}

model PetOwner {
  petId        String
  ownerId      String
  isPrimary    Boolean @default(false)
  relationship String?

  pet   Pet   @relation(fields: [petId], references: [id], onDelete: Cascade)
  owner Owner @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@id([petId, ownerId])
  @@map("pet_owners")
}

model ServiceCatalog {
  id                 String     @id
  name               String
  description        String?
  durationMin        Int        @default(60)
  pricingModel       String     @default("fixed")
  priceToy           Float?
  pricePequeno       Float?
  priceMediano       Float?
  priceGrandeFixed   Float?
  priceGrandeHourly  Float?
  priceGiganteHourly Float?
  isActive           Boolean    @default(true)
  sortOrder          Int        @default(0)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  appointments Appointment[]

  @@map("service_catalog")
}

model Appointment {
  id                String            @id @default(cuid())
  status            String   @default("pending")
  startDateTime     DateTime
  endDateTime       DateTime
  priceType         String   @default("fixed")
  estimatedHours    Float?
  actualHours       Float?
  totalAmount       Float?
  notes             String?
  source            String   @default("presencial")
  bookingToken      String?           @unique
  googleEventId     String?
  confirmedAt       DateTime?
  cancelledAt       DateTime?
  completedAt       DateTime?
  cancellationReason String?
  reminder2dSent    Boolean           @default(false)
  reminder1dSent    Boolean           @default(false)
  reminder2hSent    Boolean           @default(false)
  reviewSent        Boolean           @default(false)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  ownerId   String
  petId     String
  serviceId String
  staffId   String

  owner   Owner          @relation(fields: [ownerId], references: [id])
  pet     Pet            @relation(fields: [petId], references: [id])
  service ServiceCatalog @relation(fields: [serviceId], references: [id])
  staff   User           @relation("StaffAppointments", fields: [staffId], references: [id])
  ticket        Ticket?
  pipelineSteps AppointmentPipelineStep[]

  @@index([staffId, startDateTime])
  @@index([ownerId])
  @@index([petId])
  @@index([startDateTime])
  @@index([status])
  @@map("appointments")
}

model AppointmentPipelineStep {
  id            String   @id @default(cuid())
  step          String
  label         String
  sortOrder     Int
  completedAt   DateTime?
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@unique([appointmentId, step])
  @@map("appointment_pipeline_steps")
}

model Ticket {
  id            String        @id @default(cuid())
  number        String        @unique
  totalAmount   Float
  paymentMethod String
  paymentStatus String       @default("pending")
  createdAt     DateTime      @default(now())

  appointmentId String    @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  invoice       Invoice?
  refunds       Refund[]

  @@map("tickets")
}

model Invoice {
  id          String   @id @default(cuid())
  number      String   @unique
  companyName String
  cif         String
  address     String?
  subtotal    Float
  ivaRate     Float    @default(21.00)
  ivaAmount   Float
  total       Float
  createdAt   DateTime @default(now())

  ticketId String @unique
  ticket   Ticket  @relation(fields: [ticketId], references: [id])

  @@map("invoices")
}

model Refund {
  id            String        @id @default(cuid())
  amount        Float
  reason        String
  refundMethod  String
  isPartial     Boolean       @default(false)
  createdAt     DateTime      @default(now())

  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id])

  @@map("refunds")
}

model ProductSale {
  id            String        @id @default(cuid())
  productName   String
  quantity      Int           @default(1)
  unitPrice     Float
  totalAmount   Float
  paymentMethod String
  createdAt     DateTime      @default(now())

  ownerId String
  owner   Owner @relation(fields: [ownerId], references: [id])

  @@map("product_sales")
}

model Product {
  id          String   @id
  name        String
  description String?
  price       Float
  category    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("products")
}

model Notification {
  id        String             @id @default(cuid())
  type      String
  channel   String
  recipient String
  title     String?
  body      String
  status    String             @default("pending")
  sentAt    DateTime?
  metadata  String?
  createdAt DateTime           @default(now())

  ownerId  String
  owner    Owner  @relation(fields: [ownerId], references: [id])
  ticketId String?

  @@index([status])
  @@index([createdAt])
  @@map("notifications")
}

model NotificationConfig {
  id        String             @id @default(cuid())
  type      String
  channel   String
  enabled   Boolean            @default(true)
  ownerId   String?
  owner     Owner?             @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([type, channel, ownerId])
  @@map("notification_configs")
}

model ConsentRecord {
  id        String   @id @default(cuid())
  type      String
  version   String
  accepted  Boolean
  textShown String
  ipAddress String?
  revokedAt DateTime?
  createdAt DateTime @default(now())

  ownerId String
  owner   Owner @relation(fields: [ownerId], references: [id])

  @@map("consent_records")
}

model DataDeletionRequest {
  id          String   @id @default(cuid())
  requestType String
  description String?
  status      String   @default("pending")
  completedAt DateTime?
  notes       String?
  createdAt   DateTime @default(now())

  ownerId String
  owner   Owner @relation(fields: [ownerId], references: [id])

  @@map("data_deletion_requests")
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  entityType String
  entityId   String?
  details    String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  userId String?
  user   User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model GoogleCalendarToken {
  id           String   @id @default(cuid())
  accessToken  String
  refreshToken String
  expiryDate   DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  @@map("google_calendar_tokens")
}
