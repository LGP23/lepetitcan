{
  "expo": {
    "name": "Le Petit Can",
    "slug": "le-petit-can",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "lepetitcan",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#FFF8F3"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "es.lepetitcan.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFF8F3"
      },
      "package": "es.lepetitcan.app"
    },
    "platforms": ["ios", "android"],
    "plugins": [
      "expo-web-browser"
    ]
  }
}
